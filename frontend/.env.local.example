# Optional public base URL for browser-side dashboard/API calls.
# Leave unset for automatic host detection (http://<current-host>:8000).
NEXT_PUBLIC_API_BASE_URL=

# Server-side backend URL used by frontend /api/chat proxy route.
# Keep this as localhost when frontend and backend run on the same machine.
BACKEND_SERVER_URL=http://127.0.0.1:8000
