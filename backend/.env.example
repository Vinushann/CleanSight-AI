# Use ONE of these. Path can be absolute or relative to backend/.
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=service-account.json

# Backend server bind settings (fixed every run)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false

# Base URL used by backend/simulate_iot_session.py
# For local-only use: http://127.0.0.1:8000
# For ESP32/LAN use:  http://<YOUR_COMPUTER_LAN_IP>:8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# OpenAI for chatbot (LangChain backend agent)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
